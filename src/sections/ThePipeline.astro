---
import PipelineDoodle from '../components/PipelineDoodle.astro';
---

<section id="pipeline" class="py-16 md:py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-base-content">
        How I Work
      </h2>
      <p class="text-base md:text-lg text-base-content/60 max-w-2xl mx-auto">
        From idea to production, emphasizing measurement, automation, and continuous optimization across AI infrastructure and full-stack systems.
      </p>
    </div>
    
    <!-- The Pipeline Doodle -->
    <div class="mb-12">
      <PipelineDoodle />
    </div>
    
    <!-- Key Metrics -->
    <div class="grid grid-cols-3 gap-4 md:gap-8 max-w-3xl mx-auto">
      <div class="text-center p-4 md:p-6 bg-base-200 rounded-xl">
        <div class="text-2xl md:text-4xl font-bold text-primary mb-2">90%</div>
        <div class="text-xs md:text-sm text-base-content/60">Bug reduction via Canary</div>
      </div>
      <div class="text-center p-4 md:p-6 bg-base-200 rounded-xl">
        <div class="text-2xl md:text-4xl font-bold text-secondary mb-2">700+</div>
        <div class="text-xs md:text-sm text-base-content/60">Daily active LLM users</div>
      </div>
      <div class="text-center p-4 md:p-6 bg-base-200 rounded-xl">
        <div class="text-2xl md:text-4xl font-bold text-accent mb-2">7+</div>
        <div class="text-xs md:text-sm text-base-content/60">Years of experience</div>
      </div>
    </div>
    
    <!-- Philosophy Note -->
    <div class="mt-12 text-center">
      <p class="text-sm md:text-base text-base-content/50 font-mono">
        Ship fast · Measure impact · Iterate continuously
      </p>
    </div>
  </div>
</section>
