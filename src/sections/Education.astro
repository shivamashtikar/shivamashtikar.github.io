---
import { personal, education } from '../data/site.js';
---

<section id="education" class="text-center py-16">
  <h2 class="text-4xl font-bold mb-8 dark:text-gray-100">Education</h2>
  
  <div class="max-w-2xl mx-auto">
    <h3 class="text-2xl font-semibold mb-2 dark:text-gray-100">
      {education.degree}
    </h3>
    <p class="text-lg text-gray-600 dark:text-gray-300 mb-2">
      {education.institution}
    </p>
    <p class="text-md text-gray-500 dark:text-gray-400">
      CGPA: {education.cgpa} | {education.years}
    </p>
  </div>
</section>
