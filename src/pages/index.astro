---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../sections/Hero.astro';
import WhatIDo from '../sections/WhatIDo.astro';
import Experience from '../sections/Experience.astro';
import ToolkitTabs from '../components/ToolkitTabs.jsx';
import Education from '../sections/Education.astro';
import { personal } from '../data/site.js';

const title = `${personal.name} | Software Engineer`;
const description = `${personal.tagline}. Specializing in AI/ML systems, functional programming, and cloud infrastructure.`;
---

<Layout title={title} description={description}>
  <Header />
  
  <main>
    <Hero />
    
    <div id="content" class="container max-w-screen-lg mx-auto px-6 py-12 scroll-mt-20">
      <WhatIDo />
      <Experience />
      
      <!-- Interactive Toolkit as Island -->
      <ToolkitTabs client:visible />
      
      <Education />
    </div>
  </main>
  
  <Footer />
</Layout>
