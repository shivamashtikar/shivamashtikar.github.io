---
import { personal } from '../data/site.js';

const currentYear = new Date().getFullYear();

// Decode HTML entities to get the actual email
const decodedEmail = personal.emailEncoded.replace(/&#(\d+);/g, (_, code) => String.fromCharCode(parseInt(code)));
---

<footer class="bg-base-200 mt-12 py-4 pb-6 border-t border-base-300">
  <!-- Desktop Footer Content -->
  <div class="hidden md:block container max-w-screen-lg mx-auto px-6 text-center">
    <p class="text-base-content/70 mb-4">
      Always curious, always building — let's connect!
    </p>
    
    <div class="flex flex-wrap items-center justify-center gap-4 md:gap-6 text-sm">
      <a
        href={`mailto:${decodedEmail}`}
        class="text-primary hover:underline font-medium flex items-center gap-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        {decodedEmail}
      </a>
    </div>
    
    <p class="mt-4 text-sm text-base-content/50">
      © {currentYear} Shivam Ashtikar. Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:underline">Astro</a>.
    </p>
  </div>
  
  <!-- Mobile Footer Content - Minimal -->
  <div class="md:hidden container max-w-screen-lg mx-auto px-6 text-center pt-2 pb-4">
    <p class="text-xs text-base-content/50">
      © {currentYear} Shivam Ashtikar · Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:underline">Astro</a>
    </p>
  </div>
</footer>
