---
import { hostedTools } from '../data/workbench.js';
---

<section id="workbench-teaser" class="py-16">
  <div class="max-w-4xl mx-auto px-4 md:px-6">
    {/* Header */}
    <div class="text-center mb-8">
      <h2 class="text-3xl font-bold mb-3 text-base-content">
        Tools I've selfhosted
      </h2>
      <p class="text-base text-base-content/70 max-w-xl mx-auto">
        Open resources I maintain for the developer community. 
        Free utilities and services hosted on my infrastructure.
      </p>
    </div>

    {/* Tools List */}
    <div class="flex flex-col items-center gap-3 mb-8">
      {hostedTools.map((tool) => (
        <a 
          href={tool.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-primary hover:underline font-medium"
        >
          {tool.name}
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      ))}
      
      {/* CTA Button - Same centered format */}
      <a 
        href="/workbench"
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-primary text-primary-content text-sm font-medium shadow-md hover:shadow-lg hover:opacity-90 transition-all mt-2"
      >
        Browse Workbench
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
