---
import { personal, social } from '../data/site.js';
---

<section
  id="about"
  class="min-h-[70vh] flex flex-col justify-center px-6 py-20 relative"
>
  <div class="max-w-6xl mx-auto w-full">
    <!-- Desktop: Side-by-side / Mobile: Stacked -->
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      
      <!-- Left: Identity -->
      <div class="text-center lg:text-left">
        <!-- Name -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-base-content mb-3">
          {personal.name}
        </h1>
        
        <!-- Decorative line -->
        <div class="h-1 w-24 bg-primary mx-auto lg:mx-0 mb-6 rounded-full"></div>
        
        <!-- Title -->
        <p class="text-lg md:text-xl text-primary font-medium mb-2">
          {personal.title}
        </p>
        
        <!-- Subtitle -->
        <p class="text-base text-base-content/60">
          Juspay · 7+ years experience
        </p>
      </div>
      
      <!-- Right: Description & Actions -->
      <div class="text-center lg:text-left">
        <!-- Bio -->
        <p class="text-base md:text-lg text-base-content/80 leading-relaxed mb-8">
          {personal.tagline}
        </p>
        
        <!-- Skill Tags -->
        <div class="flex flex-wrap gap-2 justify-center lg:justify-start mb-8">
          <span class="px-3 py-1.5 bg-base-200 rounded-full text-sm font-mono text-cyan">
            LLM Inference
          </span>
          <span class="px-3 py-1.5 bg-base-200 rounded-full text-sm font-mono text-magenta">
            GPU Infrastructure
          </span>
          <span class="px-3 py-1.5 bg-base-200 rounded-full text-sm font-mono text-green">
            Functional Programming
          </span>
          <span class="px-3 py-1.5 bg-base-200 rounded-full text-sm font-mono text-yellow">
            Team Leadership
          </span>
        </div>
        
        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
          <a 
            href="#experience" 
            class="px-6 py-3 bg-primary text-primary-content rounded-lg font-semibold hover:bg-primary/90 transition-all hover:scale-105 shadow-lg shadow-primary/20"
          >
            View Experience
          </a>
          <a 
            href={social.github}
            target="_blank" 
            rel="noopener noreferrer"
            class="px-6 py-3 border-2 border-base-300 rounded-lg font-semibold text-base-content hover:border-primary hover:text-primary transition-all"
          >
            GitHub
          </a>
        </div>
      </div>
      
    </div>
  </div>
</section>
