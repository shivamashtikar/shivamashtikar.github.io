---
const services = [
  {
    title: "Backend & Frontend",
    description: "Architect and develop systems with a focus on scalability and performance.",
    icon: "code"
  },
  {
    title: "Team Leadership",
    description: "Lead cross-functional teams and provide technical mentorship to developers.",
    icon: "users"
  },
  {
    title: "Hands-On Coding",
    description: "Actively involved in coding, debugging, and tuning software systems.",
    icon: "terminal"
  },
  {
    title: "Infrastructure & Automation",
    description: "Build infrastructure automation tools, payment systems, and data engineering pipelines.",
    icon: "server"
  }
];

const icons = {
  code: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
  users: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
  terminal: "M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
  server: "M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"
};
---

<section id="what-i-do" class="mb-24">
  <h2 class="text-4xl font-bold text-center mb-12 text-base-content">What I Do</h2>

  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
    {services.map((service) => (
      <article class="bg-base-200 p-6 rounded-xl shadow-lg hover:shadow-xl transition-shadow">
        <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icons[service.icon]} />
          </svg>
        </div>
        <h3 class="text-xl font-semibold mb-2 text-base-content">{service.title}</h3>
        <p class="text-base-content/70 text-sm leading-relaxed">{service.description}</p>
      </article>
    ))}
  </div>
</section>
