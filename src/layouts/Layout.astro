---
export interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image = '/og-image.jpg' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Shivam Ashtikar" />
    <meta name="robots" content="index, follow" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Shivam Ashtikar" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:site" content="@shivamashtikar" />
    <meta property="twitter:creator" content="@shivamashtikar" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site)} />
    
    <!-- Theme Script (Prevent FOUC) -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme') || 
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.classList.remove('light', 'dark');
        document.documentElement.classList.add(theme);
      })();
    </script>
    
    <!-- Structured Data: Person -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Shivam Ashtikar",
      "givenName": "Shivam",
      "familyName": "Ashtikar",
      "jobTitle": "Software Engineer II",
      "worksFor": {
        "@type": "Organization",
        "name": "Juspay",
        "url": "https://juspay.io",
        "sameAs": "https://www.linkedin.com/company/juspay-technologies-pvt-ltd/"
      },
      "url": "https://shivamashtikar.github.io",
      "image": "https://shivamashtikar.github.io/og-image.jpg",
      "sameAs": [
        "https://github.com/shivamashtikar",
        "https://linkedin.com/in/shivamashtikar"
      ],
      "knowsAbout": [
        "Haskell",
        "PureScript",
        "AI/ML",
        "Large Language Models",
        "Cloud Infrastructure",
        "Kubernetes",
        "Docker",
        "Payment Systems",
        "Functional Programming",
        "AWS",
        "Google Cloud"
      ],
      "alumniOf": {
        "@type": "CollegeOrUniversity",
        "name": "Pune University - Government College of Engineering and Research, Avasari",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Avasari Khurd",
          "addressRegion": "Maharashtra",
          "addressCountry": "India"
        }
      }
    })} />
    
    <!-- Structured Data: Website -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Shivam Ashtikar - Portfolio",
      "url": "https://shivamashtikar.github.io",
      "author": {
        "@type": "Person",
        "name": "Shivam Ashtikar"
      }
    })} />
    
    <!-- Preconnect for Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://github.com" />
    <link rel="dns-prefetch" href="https://linkedin.com" />
    <link rel="dns-prefetch" href="https://juspay.io" />
  </head>
  <body class="bg-gray-50 text-gray-800 dark:bg-gray-900 dark:text-gray-200 antialiased">
    <slot />
  </body>
</html>
