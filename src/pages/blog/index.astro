---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { externalPosts } from '../../data/external-posts.js';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Format date for display
function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
}

// Generate post URL from date and slug
function getPostUrl(post: typeof sortedPosts[0]): string {
  const date = post.data.date;
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  return `/blog/${year}/${month}/${post.id}`;
}

// Combine local and external posts
const allPosts = [
  ...sortedPosts.map(post => ({
    id: post.id,
    title: post.data.title,
    description: post.data.description,
    date: post.data.date,
    url: getPostUrl(post),
    platform: null,
    isExternal: false
  })),
  ...externalPosts.map(post => ({
    id: post.id,
    title: post.title,
    description: post.description,
    date: post.date,
    url: post.url,
    platform: post.platform,
    isExternal: true
  }))
];

// Sort by date (newest first)
const combinedPosts = allPosts.sort((a, b) => b.date.valueOf() - a.date.valueOf());

// Redirect to home if no posts
if (combinedPosts.length === 0) {
  return Astro.redirect('/');
}
---

<Layout 
  title="Blog | Shivam Ashtikar" 
  description="Thoughts on functional programming, terminal workflows, and software engineering."
>
  <Header />
  
  <main class="min-h-screen bg-base-100 pb-20 md:pb-0">
    <div class="container max-w-screen-lg mx-auto px-6 py-16">
      <!-- Header Section -->
      <div class="text-center mb-16">
        <h1 class="text-3xl md:text-4xl font-bold text-base-content mb-4">
          Blog
        </h1>
        <p class="text-lg text-base-content/70 max-w-2xl mx-auto">
          Thoughts on functional programming, terminal workflows, and software engineering.
        </p>
      </div>

      <!-- Blog Posts Grid -->
      <div class="grid gap-8 md:gap-12">
        {combinedPosts.map((post) => (
          <article class="group">
            <a 
              href={post.url} 
              class="block"
              {...(post.isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {})}
            >
              <div class="card bg-base-200 hover:bg-base-300 transition-colors duration-300 border border-base-300">
                <div class="card-body p-6 md:p-8">
                  <!-- Date & Platform Badge -->
                  <div class="flex items-center justify-between mb-2">
                    <time class="text-sm text-base-content/60">
                      {post.isExternal 
                        ? `Published on ${post.platform} • ${formatDate(post.date)}`
                        : formatDate(post.date)
                      }
                    </time>
                    {post.isExternal && (
                      <span class="badge badge-primary badge-outline text-xs">
                        {post.platform} ↗
                      </span>
                    )}
                  </div>
                  
                  <!-- Title -->
                  <h2 class="card-title text-xl md:text-2xl font-bold text-base-content group-hover:text-primary transition-colors mb-3">
                    {post.title}
                  </h2>
                  
                  <!-- Description -->
                  <p class="text-base text-base-content/80 leading-relaxed">
                    {post.description}
                  </p>
                  
                  <!-- Read More Link -->
                  <div class="card-actions justify-start mt-4">
                    <span class="text-primary font-semibold group-hover:underline">
                      {post.isExternal ? `Read on ${post.platform} →` : 'Read more →'}
                    </span>
                  </div>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </main>
  
  <div class="hidden md:block">
    <Footer />
  </div>
</Layout>
