---
import { personal, education } from '../data/site.js';
---

<section id="education" class="py-16">
  <div class="max-w-4xl mx-auto px-4 md:px-6 text-center">
    <h2 class="text-3xl font-bold mb-8 text-base-content">Education</h2>
    <h3 class="text-xl font-semibold mb-2 text-base-content">
      {education.degree}
    </h3>
    <p class="text-base text-base-content/70 mb-2">
      {education.institution}
    </p>
    <p class="text-md text-base-content/60">
      CGPA: {education.cgpa} | {education.years}
    </p>
  </div>
</section>
