---
const navItems = [
  {
    href: '/',
    label: 'Home',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />'
  },
  {
    href: '/blog',
    label: 'Blog',
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />'
  }
];

const currentPath = Astro.url.pathname;
---

<nav class="fixed bottom-0 left-0 right-0 bg-base-200 border-t border-base-300 z-40 md:hidden">
  <div class="grid grid-cols-2 h-16">
    {navItems.map((item) => {
      const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
      return (
        <a
          href={item.href}
          class:list={[
            "flex flex-col items-center justify-center gap-1",
            "press-effect",
            isActive ? "text-primary" : "text-base-content/70"
          ]}
          aria-current={isActive ? "page" : undefined}
        >
          <svg 
            class="h-6 w-6" 
            fill="none" 
            viewBox="0 0 24 24" 
            stroke="currentColor"
            aria-hidden="true"
          >
            <Fragment set:html={item.icon} />
          </svg>
          <span class="text-xs font-medium">{item.label}</span>
        </a>
      );
    })}
  </div>
</nav>

<style>
  .press-effect {
    position: relative;
    transition: transform 0.1s ease;
  }

  .press-effect:active {
    transform: scale(0.95);
  }

  .press-effect::after {
    content: '';
    position: absolute;
    inset: 0;
    background-color: currentColor;
    opacity: 0;
    border-radius: 0.5rem;
    transition: opacity 0.2s ease;
  }

  .press-effect:active::after {
    opacity: 0.1;
  }
</style>
