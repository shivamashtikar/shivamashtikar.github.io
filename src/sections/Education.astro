---
import { personal, education } from '../data/site.js';
---

<section id="education" class="text-center py-16">
  <h2 class="text-4xl font-bold mb-8 text-base-content">Education</h2>

  <div class="max-w-2xl mx-auto">
    <h3 class="text-2xl font-semibold mb-2 text-base-content">
      {education.degree}
    </h3>
    <p class="text-lg text-base-content/70 mb-2">
      {education.institution}
    </p>
    <p class="text-md text-base-content/60">
      CGPA: {education.cgpa} | {education.years}
    </p>
  </div>
</section>
