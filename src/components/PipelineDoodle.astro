---
/**
 * Pipeline Doodle - Responsive Version
 * Desktop: Horizontal flow, Mobile: Vertical stack
 * Aesthetics: Amazon-style stylized smile-curves with explicit spaces between boxes and arrows.
 */
---

<div class="pipeline-doodle hidden md:block w-full">
  <svg
    viewBox="0 0 800 360"
    class="w-full h-auto max-h-[400px]"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g transform="translate(150, 180)">
      <rect
        x="-60" y="-40" width="120" height="80"
        rx="4"
        fill="none"
        stroke="var(--color-blue)"
        stroke-width="2.5"
        class="stage-box"
      />
      <text x="0" y="-5" text-anchor="middle" font-size="32">💡</text>
      <text
        x="0" y="25"
        text-anchor="middle"
        font-family="var(--font-chalkboard)"
        font-size="16"
        fill="var(--color-blue)"
        font-weight="600"
      >IDEA</text>
    </g>

    <g>
      <line
        x1="215" y1="180"
        x2="338" y2="180"
        stroke="var(--color-gutter)"
        stroke-width="2"
        stroke-dasharray="5,3"
      />
      <polygon
        points="338,180 331,175 331,185"
        fill="var(--color-gutter)"
      />
      <text
        x="276" y="170"
        text-anchor="middle"
        font-family="var(--font-mono)"
        font-size="10"
        fill="var(--color-yellow)"
      >code</text>
    </g>

    <g transform="translate(400, 180)">
      <rect
        x="-60" y="-40" width="120" height="80"
        rx="4"
        fill="none"
        stroke="var(--color-magenta)"
        stroke-width="2.5"
        class="stage-box"
      />
      <text x="0" y="-5" text-anchor="middle" font-size="32">👨‍💻</text>
      <text
        x="0" y="25"
        text-anchor="middle"
        font-family="var(--font-chalkboard)"
        font-size="16"
        fill="var(--color-magenta)"
        font-weight="600"
      >BUILD</text>
    </g>

    <g>
      <line
        x1="465" y1="180"
        x2="583" y2="180"
        stroke="var(--color-gutter)"
        stroke-width="2"
        stroke-dasharray="5,3"
      />
      <polygon
        points="583,180 576,175 576,185"
        fill="var(--color-gutter)"
      />
      <text
        x="524" y="170"
        text-anchor="middle"
        font-family="var(--font-mono)"
        font-size="10"
        fill="var(--color-yellow)"
      >deploy</text>
    </g>

    <g transform="translate(650, 180)">
      <rect
        x="-60" y="-40" width="120" height="80"
        rx="4"
        fill="none"
        stroke="var(--color-green)"
        stroke-width="2.5"
        class="stage-box"
      />
      <text x="0" y="-5" text-anchor="middle" font-size="32">🚀</text>
      <text
        x="0" y="25"
        text-anchor="middle"
        font-family="var(--font-chalkboard)"
        font-size="16"
        fill="var(--color-green)"
        font-weight="600"
      >SHIP</text>
    </g>

    <g>
      <path
        d="M 650 250 C 650 340, 150 340, 150 250"
        fill="none"
        stroke="var(--color-yellow)"
        stroke-width="2.5"
        stroke-dasharray="8,4"
        opacity="0.7"
      />
      <polygon
        points="150,238 145,248 155,250"
        fill="var(--color-yellow)"
        opacity="0.7"
      />
      <text
        x="400" y="295"
        text-anchor="middle"
        font-family="var(--font-mono)"
        font-size="10"
        fill="var(--color-yellow)"
        opacity="0.8"
      >feedback loop</text>
    </g>

    <g transform="translate(150, 80)">
      <circle cx="0" cy="0" r="3" fill="var(--color-blue)" />
      <text x="10" y="4" font-family="var(--font-chalkboard)" font-size="14" fill="var(--color-blue)" font-weight="600">SDLC</text>
      <text x="10" y="20" font-family="var(--font-mono)" font-size="10" fill="var(--color-yellow)">Systems Thinking</text>
    </g>

    <g transform="translate(400, 80)">
      <circle cx="0" cy="0" r="3" fill="var(--color-magenta)" />
      <text x="10" y="4" font-family="var(--font-chalkboard)" font-size="14" fill="var(--color-magenta)" font-weight="600">AI / ML</text>
      <text x="10" y="20" font-family="var(--font-mono)" font-size="10" fill="var(--color-yellow)">GPU · vLLM · 700+ Users</text>
    </g>

    <g transform="translate(650, 80)">
      <circle cx="0" cy="0" r="3" fill="var(--color-green)" />
      <text x="10" y="4" font-family="var(--font-chalkboard)" font-size="14" fill="var(--color-green)" font-weight="600">Leadership</text>
      <text x="10" y="20" font-family="var(--font-mono)" font-size="10" fill="var(--color-yellow)">Mentoring · Growth</text>
    </g>
  </svg>
</div>

<div class="pipeline-doodle-mobile md:hidden w-full">
  <svg
    viewBox="0 0 320 450"
    class="w-full h-auto"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g transform="translate(160, 25)">
      <circle cx="-55" cy="0" r="3" fill="var(--color-blue)" />
      <text x="-45" y="4" font-family="var(--font-chalkboard)" font-size="13" fill="var(--color-blue)" font-weight="600">SDLC</text>
    </g>

    <g transform="translate(160, 75)">
      <rect
        x="-80" y="-38" width="160" height="76"
        rx="4"
        fill="none"
        stroke="var(--color-blue)"
        stroke-width="2.5"
        class="stage-box"
      />
      <text x="0" y="-8" text-anchor="middle" font-size="36">💡</text>
      <text
        x="0" y="22"
        text-anchor="middle"
        font-family="var(--font-chalkboard)"
        font-size="20"
        fill="var(--color-blue)"
        font-weight="600"
      >IDEA</text>
    </g>

    <g>
      <line
        x1="160" y1="118"
        x2="160" y2="152"
        stroke="var(--color-gutter)"
        stroke-width="2"
        stroke-dasharray="5,3"
      />
      <polygon
        points="160,158 155,150 165,150"
        fill="var(--color-gutter)"
      />
      <text
        x="175" y="140"
        font-family="var(--font-mono)"
        font-size="10"
        fill="var(--color-yellow)"
      >code</text>
    </g>

    <g transform="translate(160, 165)">
      <circle cx="-60" cy="0" r="3" fill="var(--color-magenta)" />
      <text x="-50" y="4" font-family="var(--font-chalkboard)" font-size="13" fill="var(--color-magenta)" font-weight="600">AI / ML</text>
    </g>

    <g transform="translate(160, 215)">
      <rect
        x="-80" y="-38" width="160" height="76"
        rx="4"
        fill="none"
        stroke="var(--color-magenta)"
        stroke-width="2.5"
        class="stage-box"
      />
      <text x="0" y="-8" text-anchor="middle" font-size="36">👨‍💻</text>
      <text
        x="0" y="22"
        text-anchor="middle"
        font-family="var(--font-chalkboard)"
        font-size="20"
        fill="var(--color-magenta)"
        font-weight="600"
      >BUILD</text>
    </g>

    <g>
      <line
        x1="160" y1="258"
        x2="160" y2="292"
        stroke="var(--color-gutter)"
        stroke-width="2"
        stroke-dasharray="5,3"
      />
      <polygon
        points="160,298 155,290 165,290"
        fill="var(--color-gutter)"
      />
      <text
        x="175" y="280"
        font-family="var(--font-mono)"
        font-size="10"
        fill="var(--color-yellow)"
      >deploy</text>
    </g>

    <g transform="translate(160, 305)">
      <circle cx="-65" cy="0" r="3" fill="var(--color-green)" />
      <text x="-55" y="4" font-family="var(--font-chalkboard)" font-size="13" fill="var(--color-green)" font-weight="600">Leadership</text>
    </g>

    <g transform="translate(160, 355)">
      <rect
        x="-80" y="-38" width="160" height="76"
        rx="4"
        fill="none"
        stroke="var(--color-green)"
        stroke-width="2.5"
        class="stage-box"
      />
      <text x="0" y="-8" text-anchor="middle" font-size="36">🚀</text>
      <text
        x="0" y="22"
        text-anchor="middle"
        font-family="var(--font-chalkboard)"
        font-size="20"
        fill="var(--color-green)"
        font-weight="600"
      >SHIP</text>
    </g>

    <g>
      <path
        d="M 80 365 C -5 365, -5 65, 80 65"
        fill="none"
        stroke="var(--color-yellow)"
        stroke-width="2.5"
        stroke-dasharray="8,4"
        opacity="0.7"
      />
      <polygon
        points="80,65 72,58 88,58"
        fill="var(--color-yellow)"
        opacity="0.7"
      />
      <text
        x="28" y="215"
        text-anchor="middle"
        font-family="var(--font-mono)"
        font-size="10"
        fill="var(--color-yellow)"
        opacity="0.8"
        transform="rotate(-90, 28, 215)"
      >feedback loop</text>
    </g>
  </svg>
</div>

<style>
  .pipeline-doodle,
  .pipeline-doodle-mobile {
    color: inherit;
  }

  .stage-box {
    transition: all 0.3s ease;
  }
</style>
